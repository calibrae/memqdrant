# ── palazzo Docker Compose configuration ─────────────────────────────────
# Copy to .env and edit:  cp .env.example .env

# ── Embedding backend (baked in at image-build time) ─────────────────────
# fastembed = local ONNX nomic-embed-text-v1.5-Q, self-contained (default)
# ollama    = HTTP to an Ollama server (needs OLLAMA_URL reachable)
PALAZZO_BACKEND=fastembed

# ── Which services to bundle (Compose profiles) ──────────────────────────
# Comma-separated list of profiles to activate:
#   qdrant  — run a bundled Qdrant container
#   ollama  — run a bundled Ollama container
# Leave empty to use external services (set the *_URL vars below).
#   COMPOSE_PROFILES=qdrant          self-contained: fastembed + bundled Qdrant
#   COMPOSE_PROFILES=qdrant,ollama   bundled Qdrant + bundled Ollama
#   COMPOSE_PROFILES=                everything external
COMPOSE_PROFILES=qdrant

# ── Qdrant ───────────────────────────────────────────────────────────────
# With the "qdrant" profile active, leave QDRANT_URL as the service name.
# For an external Qdrant, set the full URL, e.g. http://10.10.0.3:6333
QDRANT_URL=http://qdrant:6333
COLLECTION=claude-memory
QDRANT_VERSION=latest
QDRANT_PORT=6333

# ── Ollama (only used when PALAZZO_BACKEND=ollama) ───────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_VERSION=latest
OLLAMA_PORT=11434

# ── palazzo service ──────────────────────────────────────────────────────
# Host port the MCP endpoint is published on (container always listens :6334).
PALAZZO_PORT=6334
# DNS-rebinding Host-header allowlist. "*" disables the check (trusted LAN).
PALAZZO_ALLOWED_HOSTS=*
RUST_LOG=palazzo=info
