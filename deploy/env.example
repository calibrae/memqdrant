# /etc/palazzo/env — Environment file for the systemd service.
# Copy to /etc/palazzo/env and tune for your infrastructure.

# Qdrant endpoint. palazzo runs on the same host as Qdrant in most deployments.
QDRANT_URL=http://127.0.0.1:6333

# Ollama endpoint (only used by the `ollama` backend; ignored under `fastembed`).
OLLAMA_URL=http://127.0.0.1:11434

# Override if embedding model differs.
OLLAMA_MODEL=nomic-embed-text

# Collection name. Must be 768-dim cosine if you plan to share with the existing palace.
COLLECTION=claude-memory

# WAL destination. Must be writable by the `palazzo` system user.
PALAZZO_WAL=/var/lib/palazzo/wal.jsonl

# Bind address. 0.0.0.0 for LAN access, 127.0.0.1 for localhost-only (+reverse proxy).
PALAZZO_BIND=0.0.0.0:6334

# Comma-separated Host-header allowlist (DNS rebinding protection).
# Defaults to localhost,127.0.0.1,::1 — override to accept remote clients that
# use a hostname or IP that isn't in the default list.
# Set to "*" to disable the check entirely (only behind a trusted proxy).
# PALAZZO_ALLOWED_HOSTS=your-hostname:6334,127.0.0.1:6334,::1

# Token-savings analytics (palace_gain). Defaults to enabled.
# PALAZZO_USAGE_LOG=/var/lib/palazzo/usage.jsonl
# PALAZZO_GAIN_ENABLED=1

# Tracing level.
RUST_LOG=palazzo=info
