# /etc/memqdrant/env — Environment file for the systemd service.
# Copy to /etc/memqdrant/env and tune for your infrastructure.

# Qdrant endpoint. memqdrant runs on the same host as Qdrant in most deployments.
QDRANT_URL=http://127.0.0.1:6333

# Ollama endpoint. nomic-embed-text must be pulled on this instance.
OLLAMA_URL=http://127.0.0.1:11434

# Override if embedding model differs.
OLLAMA_MODEL=nomic-embed-text

# Collection name. Must be 768-dim cosine if you plan to share with the existing palace.
COLLECTION=claude-memory

# WAL destination. Must be writable by the `memqdrant` system user.
MEMQDRANT_WAL=/var/lib/memqdrant/wal.jsonl

# Bind address. 0.0.0.0 for LAN access, 127.0.0.1 for localhost-only (+reverse proxy).
MEMQDRANT_BIND=0.0.0.0:6334

# Comma-separated Host-header allowlist (DNS rebinding protection).
# Defaults to localhost,127.0.0.1,::1 — override to accept remote clients that
# use a hostname or IP that isn't in the default list.
# Set to "*" to disable the check entirely (only behind a trusted proxy).
# MEMQDRANT_ALLOWED_HOSTS=your-hostname:6334,127.0.0.1:6334,::1

# Tracing level.
RUST_LOG=memqdrant=info
